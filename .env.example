# ── Blockchain ──────────────────────────────────────────
# Local Hardhat node (default)
RPC_URL=http://127.0.0.1:8545

# Testnet (Sepolia)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Mainnet
# MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Etherscan verification
# ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# ── Backend ──────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# Admin wallet private key (used to sign admin transactions)
# For local dev, use one of the Hardhat test accounts
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

JWT_SECRET=change-this-in-production-use-a-long-random-string
JWT_EXPIRES=24h

# ── Frontend (prefix with REACT_APP_) ────────────────────
# REACT_APP_API_URL=http://localhost:5000/api
